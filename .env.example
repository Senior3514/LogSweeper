# LogSweeper Configuration
LOGSWEEPER_DB_PATH=logsweeper.db
LOGSWEEPER_HOST=0.0.0.0
LOGSWEEPER_PORT=8093
LOGSWEEPER_SECRET_KEY=change-me-in-production
LOGSWEEPER_LOG_LEVEL=INFO
# Optional: API key for endpoint authentication (leave unset to disable)
# LOGSWEEPER_API_KEY=your-secret-api-key-here
# Optional: Postgres DSN for production
# LOGSWEEPER_DATABASE_URL=postgresql://user:pass@localhost:5432/logsweeper
